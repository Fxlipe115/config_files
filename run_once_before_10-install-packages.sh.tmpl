#!/usr/bin/env bash
set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
MODULES=({{ range .modules }}{{ . | quote }} {{ end }})

{{ if eq .chezmoi.os "darwin" -}}
# ---------------------------------------------------------------------------
# macOS — Homebrew + Brewfiles
# ---------------------------------------------------------------------------
if ! command -v brew >/dev/null 2>&1; then
    echo "Installing Homebrew..."
    NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$({{ if eq .chezmoi.arch "arm64" }}/opt/homebrew/bin/brew{{ else }}/usr/local/bin/brew{{ end }} shellenv)"

echo "Installing base Brewfile..."
brew bundle --file="$SOURCE_DIR/Brewfile"

for m in "${MODULES[@]}"; do
    if [ -f "$SOURCE_DIR/Brewfile.$m" ]; then
        echo "Installing module packages: $m"
        brew bundle --file="$SOURCE_DIR/Brewfile.$m"
    fi
done
{{ else -}}
# ---------------------------------------------------------------------------
# Linux — packages.txt via the available package manager
# ---------------------------------------------------------------------------
export DEBIAN_FRONTEND=noninteractive

install_pkg() {
    if command -v apt-get >/dev/null 2>&1; then sudo apt-get install -y "$1" </dev/null
    elif command -v dnf >/dev/null 2>&1; then sudo dnf install -y "$1" </dev/null
    elif command -v pacman >/dev/null 2>&1; then sudo pacman -S --noconfirm "$1" </dev/null
    elif command -v zypper >/dev/null 2>&1; then sudo zypper install -y "$1" </dev/null
    else echo "No supported package manager found for: $1" >&2; return 1; fi
}

install_list() {
    [ -f "$1" ] || return 0
    # Read the list on FD 3 so a package installer (e.g. debconf) can't drain it via stdin.
    while IFS= read -r pkg <&3 || [ -n "$pkg" ]; do
        pkg="${pkg%%#*}"; pkg="$(echo "$pkg" | xargs)"
        [ -z "$pkg" ] && continue
        install_pkg "$pkg" || echo "WARNING: could not install '$pkg', skipping" >&2
    done 3< "$1"
}

echo "Installing base packages..."
install_list "$SOURCE_DIR/packages.txt"

for m in "${MODULES[@]}"; do
    if [ -f "$SOURCE_DIR/packages.$m.txt" ]; then
        echo "Installing module packages: $m"
        install_list "$SOURCE_DIR/packages.$m.txt"
    fi
done
{{ end -}}
