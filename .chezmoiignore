{{/* Repo files that are not dotfiles — never apply these to $HOME */}}
README.md
LICENSE
Brewfile
Brewfile.*
packages.txt
packages.*.txt

{{/* Feature modules: skip the fragments for modules not enabled here */}}
{{- $enabled := list }}
{{- range (splitList "," .modules) }}{{ $enabled = append $enabled (trim .) }}{{ end }}
{{- range .knownModules }}
{{- if not (has . $enabled) }}
.config/zsh/modules/{{ . }}.zsh
{{- end }}
{{- end }}

{{/* SSH keys are only managed when Bitwarden is enabled (the ssh config is always applied) */}}
{{- if not .useBitwarden }}
.ssh/github
.ssh/github.pub
.ssh/git-signing
.ssh/git-signing.pub
{{- end }}
