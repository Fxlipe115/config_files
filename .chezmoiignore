{{/* Repo files that are not dotfiles — never apply these to $HOME */}}
/README.md
/LICENSE
/CLAUDE.md
Brewfile
Brewfile.*
packages.txt
packages.*.txt

{{/* VS Code user settings live at OS-specific paths — apply only the right one */}}
{{- if ne .chezmoi.os "darwin" }}
Library/Application Support/Code/User/settings.json
{{- end }}
{{- if ne .chezmoi.os "linux" }}
.config/Code/User/settings.json
{{- end }}

{{/* Feature modules: skip the fragments for modules not enabled here */}}
{{- range .knownModules }}
{{- if not (has . $.modules) }}
.config/zsh/modules/{{ . }}.zsh
{{- end }}
{{- end }}

{{/* Claude Code plugin/marketplace settings only when the claude module is enabled */}}
{{- if not (has "claude" .modules) }}
.claude/settings.json
{{- end }}

{{/* SSH keys are only managed when Bitwarden is enabled (the ssh config is always applied) */}}
{{- if not .useBitwarden }}
.ssh/github
.ssh/github.pub
.ssh/git-signing
.ssh/git-signing.pub
{{- end }}
