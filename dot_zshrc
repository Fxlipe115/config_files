# Set PATH
export PATH="$HOME/bin:$PATH"
export PATH="/usr/local/bin:$PATH"     # Standard UNIX utilities
export PATH="/usr/games:$PATH"         # Debian/Ubuntu: cowsay, fortune, lolcat
export PATH="$HOME/go/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

ZSH_DISABLE_COMPFIX=true
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="gnzh"

HYPHEN_INSENSITIVE="true"
# ENABLE_CORRECTION="true"
COMPLETION_WAITING_DOTS="true"

HIST_STAMPS="mm/dd/yyyy"

# Oh-My-Zsh plugins
plugins=(
  git
  command-not-found
  zsh-autosuggestions
  zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# Editor settings
export EDITOR='nvim'

# User configuration
alias zshconfig="nvim ~/.zshrc"
alias vimconfig="nvim ~/.config/nvim/init.lua"
alias ls="eza -l --classify=always --group-directories-first --icons=always --git"
alias l="eza -l --classify=always --group-directories-first --icons=always --git -a"
tree() {
    if [ -n "$1" ]; then
        if [ -n "$2" ]; then
            eza -l --classify=always --group-directories-first --icons=always --git -T -L "$1" "$2"
        else
            eza -l --classify=always --group-directories-first --icons=always --git -T "$1"
        fi
    else
        eza -l --classify=always --group-directories-first --icons=always --git -T
    fi
}
alias please="sudo"
alias sl="sl -e \
  \$(echo \"-a\n-l\n-F\" | shuf -n \$(shuf -i 0-3 -n 1) | paste -s -d \" \" -)"

alias gimmefortune="fortune | cowsay -n \
  -f \$(cowsay -l | tail -n +2 | tr ' ' '\n' | shuf -n1) | lolcat"

if [[ -z "$SKIP_BYOBU" ]]; then
    neofetch --ascii "$(gimmefortune)" | lolcat -ts 60 # -ad 7
fi

export TERM=xterm-256color

COWPATH="$COWPATH:$HOME/.cowsay"

eval "$(thefuck --alias 2>/dev/null)"

#alias python=python3
alias sqlite=sqlite3

alias vim=nvim

alias wttr="~/wttr"

eval "$(hub alias -s)"

alias info="neofetch"

# Load enabled feature modules (see ~/.config/zsh/modules/)
if [ -d "$HOME/.config/zsh/modules" ]; then
    for _mod in "$HOME"/.config/zsh/modules/*.zsh(N); do
        source "$_mod"
    done
    unset _mod
fi

# iTerm2 shell integration
test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

source ~/.fonts/*.sh(N)

[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"
