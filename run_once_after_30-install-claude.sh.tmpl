#!/usr/bin/env bash
set -euo pipefail
{{ if has "claude" .modules -}}
export PATH="$HOME/.local/bin:$PATH"

if ! command -v claude >/dev/null 2>&1; then
    echo "Installing Claude Code..."
    curl -fsSL https://claude.ai/install.sh | bash
fi

# Claude Code doesn't auto-install plugins from settings.json, so add the
# marketplaces and install the enabled plugins declared there.
settings="$HOME/.claude/settings.json"
if command -v claude >/dev/null 2>&1 && command -v jq >/dev/null 2>&1 && [ -f "$settings" ]; then
    jq -r '.extraKnownMarketplaces // {} | to_entries[] | .value.source.repo // empty' "$settings" | \
    while read -r repo; do
        [ -n "$repo" ] && claude plugin marketplace add "$repo" </dev/null >/dev/null 2>&1 || true
    done
    jq -r '.enabledPlugins // {} | to_entries[] | select(.value == true) | .key' "$settings" | \
    while read -r plugin; do
        [ -n "$plugin" ] && claude plugin install "$plugin" --scope user </dev/null >/dev/null 2>&1 || true
    done
fi
{{ end -}}
